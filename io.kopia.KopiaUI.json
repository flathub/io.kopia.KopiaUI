{
    "app-id": "io.kopia.KopiaUI",
    "base": "org.electronjs.Electron2.BaseApp",
    "base-version": "25.08",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "kopia-ui",
    "separate-locales": false,
    "rename-desktop-file": "kopia-ui.desktop",
    "rename-icon": "kopia-ui",
    "finish-args": [
        "--share=ipc",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--socket=pulseaudio",
        "--share=network",
        "--device=dri",
        "--filesystem=host",
        "--filesystem=~/.var/app/",
        "--talk-name=org.kde.StatusNotifierWatcher"
    ],
    "modules": [
        {
            "name": "kopia-ui",
            "buildsystem": "simple",
            "build-commands": [
                "ar x kopia-ui_*.deb",
                "tar xf data.tar.xz",
                "cp -r usr/* opt/* /app",
                "chmod -R a-s,go+rX,go-w /app/KopiaUI",
                "sed -i 's|Exec=.*|Exec=kopia-ui %U|' /app/share/applications/kopia-ui.desktop",
                "install kopia-ui.sh /app/bin/kopia-ui",
                "install -Dm644 io.kopia.KopiaUI.appdata.xml /app/share/appdata/io.kopia.KopiaUI.appdata.xml",
                "unzip rclone-v*-linux-*.zip",
                "install rclone-v*-linux-*/rclone /app/bin/rclone"
            ],
            "cleanup": [
                "kopia-ui_*.deb",
                "control.tar.gz",
                "data.tar.xz",
                "debian-binary"
            ],
            "sources": [
                {
                    "type": "file",
                    "only-arches": [
                        "x86_64"
                    ],
                    "url": "https://github.com/kopia/kopia/releases/download/v0.23.0/kopia-ui_0.23.0_amd64.deb",
                    "sha256": "9cb04fe42a4ee98c71323598e3241dd2be4da729d47ae003580236649ec418d0",
                    "x-checker-data": {
                        "is-main-source": true,
                        "stable-only": true,
                        "type": "json",
                        "url": "https://api.github.com/repos/kopia/kopia/releases/latest",
                        "tag-query": ".tag_name",
                        "tag-pattern": "^([d.]+)$",
                        "version-query": "$tag | sub(\"^v\"; \"\")",
                        "timestamp-query": ".published_at",
                        "url-query": ".assets[] | select(.name==\"kopia-ui_\" + $version + \"_amd64.deb\") | .browser_download_url"
                    }
                },
                {
                    "type": "file",
                    "only-arches": [
                        "aarch64"
                    ],
                    "url": "https://github.com/kopia/kopia/releases/download/v0.23.0/kopia-ui_0.23.0_arm64.deb",
                    "sha256": "1cafe5250bfa2c5b7420f61ed767a1128c287457dd2c067402f59136d6b6938d",
                    "x-checker-data": {
                        "is-main-source": true,
                        "stable-only": true,
                        "type": "json",
                        "url": "https://api.github.com/repos/kopia/kopia/releases/latest",
                        "tag-query": ".tag_name",
                        "tag-pattern": "^([d.]+)$",
                        "version-query": "$tag | sub(\"^v\"; \"\")",
                        "timestamp-query": ".published_at",
                        "url-query": ".assets[] | select(.name==\"kopia-ui_\" + $version + \"_arm64.deb\") | .browser_download_url"
                    }
                },
                {
                    "type": "file",
                    "path": "kopia-ui.sh"
                },
                {
                    "type": "file",
                    "path": "io.kopia.KopiaUI.appdata.xml"
                },
                {
                    "type": "file",
                    "only-arches": [
                        "x86_64"
                    ],
                    "url": "https://github.com/rclone/rclone/releases/download/v1.74.1/rclone-v1.74.1-linux-amd64.zip",
                    "sha256": "67df3059a6233b6e32e604bcd637654bb294ff86291b65ede77123e94818d911",
                    "x-checker-data": {
                        "type": "json",
                        "url": "https://api.github.com/repos/rclone/rclone/releases/latest",
                        "tag-query": ".tag_name",
                        "tag-pattern": "^([d.]+)$",
                        "version-query": "$tag | sub(\"^v\"; \"\")",
                        "timestamp-query": ".published_at",
                        "url-query": ".assets[] | select(.name==\"rclone-v\" + $version + \"-linux-amd64.zip\") | .browser_download_url"
                    }
                },
                {
                    "type": "file",
                    "only-arches": [
                        "aarch64"
                    ],
                    "url": "https://github.com/rclone/rclone/releases/download/v1.74.1/rclone-v1.74.1-linux-arm64.zip",
                    "sha256": "c816ed0e568de4dd1bba1a4d0cd47523d3dd54337dd5fde73f1b068857ecf877",
                    "x-checker-data": {
                        "type": "json",
                        "url": "https://api.github.com/repos/rclone/rclone/releases/latest",
                        "tag-query": ".tag_name",
                        "tag-pattern": "^([d.]+)$",
                        "version-query": "$tag | sub(\"^v\"; \"\")",
                        "timestamp-query": ".published_at",
                        "url-query": ".assets[] | select(.name==\"rclone-v\" + $version + \"-linux-arm64.zip\") | .browser_download_url"
                    }
                }
            ]
        }
    ]
}
